<manifest xmlns:android="http://schemas.android.com/apk/res/android">
    <uses-permission android:name="android.permission.ACCESS_FINE_LOCATION"/>
    <uses-permission android:name="android.permission.ACCESS_COARSE_LOCATION"/>
    <!-- SOS system's ambient "who's nearby" layer (see
         lib/core/services/sos_location_service.dart), opt-out, defaults
         on, and always paired with the foreground-service notification
         below per Play Store policy on background location. -->
    <uses-permission android:name="android.permission.ACCESS_BACKGROUND_LOCATION"/>
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE"/>
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE_LOCATION"/>
    <!-- SOS floating button's optional voice note. -->
    <uses-permission android:name="android.permission.RECORD_AUDIO"/>
    <application
        android:label="AFOS"
        android:name="${applicationName}"
        android:icon="@mipmap/ic_launcher">
        <activity
            android:name=".MainActivity"
            android:exported="true"
            android:launchMode="singleTop"
            android:taskAffinity=""
            android:theme="@style/LaunchTheme"
            android:configChanges="orientation|keyboardHidden|keyboard|screenSize|smallestScreenSize|locale|layoutDirection|fontScale|screenLayout|density|uiMode"
            android:hardwareAccelerated="true"
            android:windowSoftInputMode="adjustResize"
            android:enableOnBackInvokedCallback="false">
            <!-- Specifies an Android theme to apply to this Activity as soon as
                 the Android process has started. This theme is visible to the user
                 while the Flutter UI initializes. After that, this theme continues
                 to determine the Window background behind the Flutter UI. -->
            <meta-data
              android:name="io.flutter.embedding.android.NormalTheme"
              android:resource="@style/NormalTheme"
              />
            <intent-filter>
                <action android:name="android.intent.action.MAIN"/>
                <category android:name="android.intent.category.LAUNCHER"/>
            </intent-filter>
            <!-- Password-reset deep link — without this, the emailed link had
                 nowhere to land on Android except a browser opening the web
                 build, even when the request came from this native app. -->
            <intent-filter>
                <action android:name="android.intent.action.VIEW"/>
                <category android:name="android.intent.category.DEFAULT"/>
                <category android:name="android.intent.category.BROWSABLE"/>
                <data android:scheme="afos"/>
            </intent-filter>
        </activity>
        <!-- Don't delete the meta-data below.
             This is used by the Flutter tool to generate GeneratedPluginRegistrant.java -->
        <meta-data
            android:name="flutterEmbedding"
            android:value="2" />
        <!-- Impeller (Vulkan) hit a real device-level driver incompatibility on
             this hardware (Mali GPU: "fbcNotifySbeRescue... undefined symbol",
             "mali_gralloc: ERROR: Unrecognized and/or unsupported format" on
             every single launch), which coincided with a transient
             "BoxConstraints forces an infinite width" layout crash the moment
             Manage Hall tried to render real list items — falling back to the
             older Skia renderer avoids that driver-level instability. -->
        <meta-data
            android:name="io.flutter.embedding.android.EnableImpeller"
            android:value="false" />
        <!-- Required by flutter_background_service for the SOS ambient
             location-sharing layer, SDK 34+ requires foregroundServiceType
             to be declared explicitly for each type of foreground service.
             Only overrides foregroundServiceType here; the plugin's own
             manifest (flutter_background_service_android) already declares
             this same component with exported="true", so redeclaring a
             conflicting exported value here would break the manifest
             merge (ManifestMerger2$MergeFailureException). -->
        <service
            android:name="id.flutter.flutter_background_service.BackgroundService"
            android:foregroundServiceType="location" />
    </application>
    <!-- Required to query activities that can process text, see:
         https://developer.android.com/training/package-visibility and
         https://developer.android.com/reference/android/content/Intent#ACTION_PROCESS_TEXT.

         In particular, this is used by the Flutter engine in io.flutter.plugin.text.ProcessTextPlugin. -->
    <queries>
        <intent>
            <action android:name="android.intent.action.PROCESS_TEXT"/>
            <data android:mimeType="text/plain"/>
        </intent>
        <!-- Required by url_launcher to resolve https:// links (Google Maps
             directions) on Android 11+ package-visibility restrictions. -->
        <intent>
            <action android:name="android.intent.action.VIEW"/>
            <data android:scheme="https"/>
        </intent>
    </queries>
</manifest>
